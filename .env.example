# =============================================================================
# Vrindavan Braj Yatra - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!
# =============================================================================

# Database (PostgreSQL)
# Local: postgresql://postgres:password@localhost:5432/vrindavan_yatra
# Neon:  postgresql://user:pass@ep-xxx.neon.tech/vrindavan_yatra?sslmode=require
# Vercel Postgres: Set automatically via Vercel Integration
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/vrindavan_yatra

# For Neon on Vercel: Also set the unpooled connection for migrations
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.neon.tech/vrindavan_yatra?sslmode=require

# Neon flag (optional - auto-detected from DATABASE_URL)
# NEON=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Vrindavan Braj Yatra

# Admin Credentials
ADMIN_PASSWORD=brajyatra2024

# Optional: Email (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Optional: Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
